# ─────────────────────────────────────────────────────────────
#  NEVER-MISS-CALL  —  environment configuration
#  Copy this file to ".env" and fill in your real values.
# ─────────────────────────────────────────────────────────────

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key-here

# Realtime model. GA model is "gpt-realtime-2". Older beta was "gpt-realtime".
REALTIME_MODEL=gpt-realtime-2

# Session-config shape. The GA API ("ga") uses the nested audio.input.format
# object; the older beta API ("beta") used the flat input_audio_format field.
# If you get "Unknown parameter" errors on session.update, flip this value.
REALTIME_API_MODE=ga

# Voice for the agent. GA voices include: marin, cedar, alloy, ash, ballad,
# coral, sage, verse. "marin" and "cedar" sound the most natural on phone.
REALTIME_VOICE=marin

# --- Twilio ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# The Twilio phone number that customers call (E.164 format, e.g. +13605551234)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Public host ---
# The public hostname Twilio uses to reach this server (no protocol).
# In local dev, use an ngrok/cloudflared tunnel host, e.g. abc123.ngrok.app
PUBLIC_HOST=your-app.onrender.com

# --- Server ---
PORT=3000

# Simple shared password to view the dashboard (set anything you like).
DASHBOARD_PASSWORD=changeme

# Which business config to load (file in /config, without .json)
BUSINESS=business.example
